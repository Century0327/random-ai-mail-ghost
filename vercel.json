{
  "version": 2,
  "builds": [
    { "src": "app.py", "use": "@vercel/python" },
    { "src": "electron/renderer/app/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "app.py" },
    { "src": "/app/(.*)", "dest": "electron/renderer/app/$1" },
    { "src": "/api/(.*)", "dest": "app.py" }
  ]
}
